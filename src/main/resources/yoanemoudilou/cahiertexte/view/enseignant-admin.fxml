<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns:fx="http://javafx.com/fxml" prefWidth="980" prefHeight="650"
            fx:controller="yoanemoudilou.cahiertexte.ui.enseignants.EnseignantAssignmentController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="Enseignants et affectations" styleClass="header-label">
                <font>
                    <Font name="System Bold" size="18" />
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Retour au dashboard" onAction="#handleRetourDashboard" styleClass="button-accent" />
        </HBox>
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            <TableView fx:id="enseignantsTable" prefHeight="240">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="60" />
                    <TableColumn fx:id="nomCompletColumn" text="Enseignant" prefWidth="220" />
                    <TableColumn fx:id="emailColumn" text="Email" prefWidth="250" />
                    <TableColumn fx:id="valideColumn" text="Valide" prefWidth="80" />
                    <TableColumn fx:id="actifColumn" text="Actif" prefWidth="80" />
                </columns>
            </TableView>

            <Separator />

            <GridPane hgap="15" vgap="10">
                <Label text="Cours a attribuer:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <ComboBox fx:id="coursComboBox" prefWidth="350" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Classe:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="classeField" editable="false" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Filiere:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <TextField fx:id="filiereField" editable="false" prefWidth="200" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                <Label text="Volume horaire:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="volumeHoraireField" editable="false" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Button text="Attribuer le cours" onAction="#handleAttribuerCours" prefWidth="170" GridPane.columnIndex="3" GridPane.rowIndex="2" />
            </GridPane>

            <Separator />

            <Label text="Cours deja attribues a l'enseignant selectionne" />
            <TableView fx:id="affectationsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="codeCoursColumn" text="Code" prefWidth="100" />
                    <TableColumn fx:id="intituleCoursColumn" text="Intitule" prefWidth="260" />
                    <TableColumn fx:id="volumeColumn" text="Volume (h)" prefWidth="100" />
                    <TableColumn fx:id="classeCoursColumn" text="Classe / Filiere" prefWidth="280" />
                </columns>
            </TableView>

            <HBox alignment="CENTER" spacing="10">
                <Button text="Rafraichir" onAction="#handleRafraichir" prefWidth="120" />
            </HBox>
        </VBox>
    </center>

</BorderPane>
