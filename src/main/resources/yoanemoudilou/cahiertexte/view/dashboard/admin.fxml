<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns:fx="http://javafx.com/fxml" prefWidth="900" prefHeight="650"
            fx:controller="yoanemoudilou.cahiertexte.ui.dashboard.AdminDashboardController">

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label fx:id="bienvenuLabel" text="Bienvenue" textFill="WHITE">
                <font><Font name="System Bold" size="18"/></font>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="roleLabel" text="CHEF_DEPARTEMENT" textFill="LIGHTGRAY"/>
            <Button text="Déconnexion" onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <!-- Sidebar -->
    <left>
        <VBox spacing="10" style="-fx-background-color: #34495e; -fx-padding: 15;" prefWidth="200">
            <Label text="Navigation" textFill="WHITE">
                <font><Font name="System Bold" size="14"/></font>
            </Label>
            <Separator/>
            <Button text="📊 Tableau de bord" onAction="#handleRafraichir" prefWidth="170"/>
            <Button text="👥 Utilisateurs" onAction="#handleUsers" prefWidth="170"/>
            <Button text="🏫 Filières" onAction="#handleOuvrirFilieres" prefWidth="170"/>
            <Button text="📚 Classes" onAction="#handleOuvrirClasses" prefWidth="170"/>
            <Button text="📖 Cours" onAction="#handleCours" prefWidth="170"/>
            <Button text="📝 Séances" onAction="#handleSeances" prefWidth="170"/>
            <Button text="✅ Validation" onAction="#handleValidationSeances" prefWidth="170"/>
            <Separator/>
            <Button text="📈 Statistiques" onAction="#handleStatistiques" prefWidth="170"/>
            <Button text="📄 Rapports" onAction="#handleRapports" prefWidth="170"/>
        </VBox>
    </left>

    <!-- Centre - Statistiques -->
    <center>
        <ScrollPane fitToWidth="true">
            <VBox spacing="20" style="-fx-padding: 20;">

                <Label text="Vue d'ensemble">
                    <font><Font name="System Bold" size="18"/></font>
                </Label>

                <!-- Utilisateurs -->
                <TitledPane text="Utilisateurs" expanded="true">
                    <GridPane hgap="30" vgap="10" style="-fx-padding: 15;">
                        <Label text="Total utilisateurs:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Label fx:id="totalUtilisateursLabel" text="0" style="-fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="Enseignants:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <Label fx:id="totalEnseignantsLabel" text="0" style="-fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Responsables classe:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                        <Label fx:id="totalResponsablesLabel" text="0" style="-fx-font-weight: bold;" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                        <Label text="En attente validation:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                        <Label fx:id="utilisateursEnAttenteLabel" text="0" style="-fx-font-weight: bold; -fx-text-fill: #e67e22;" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                    </GridPane>
                </TitledPane>

                <!-- Structure pédagogique -->
                <TitledPane text="Structure pédagogique" expanded="true">
                    <GridPane hgap="30" vgap="10" style="-fx-padding: 15;">
                        <Label text="Filières:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Label fx:id="totalFilieresLabel" text="0" style="-fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="Classes:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                        <Label fx:id="totalClassesLabel" text="0" style="-fx-font-weight: bold;" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                        <Label text="Cours:" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
                        <Label fx:id="totalCoursLabel" text="0" style="-fx-font-weight: bold;" GridPane.columnIndex="5" GridPane.rowIndex="0"/>
                    </GridPane>
                </TitledPane>

                <!-- Séances -->
                <TitledPane text="Séances" expanded="true">
                    <GridPane hgap="30" vgap="10" style="-fx-padding: 15;">
                        <Label text="Total séances:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Label fx:id="totalSeancesLabel" text="0" style="-fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="En attente:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                        <Label fx:id="seancesEnAttenteLabel" text="0" style="-fx-font-weight: bold; -fx-text-fill: #e67e22;" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                        <Label text="Validées:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <Label fx:id="seancesValideesLabel" text="0" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Rejetées:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                        <Label fx:id="seancesRejeteesLabel" text="0" style="-fx-font-weight: bold; -fx-text-fill: #c0392b;" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                    </GridPane>
                </TitledPane>

                <HBox alignment="CENTER">
                    <Button text="🔄 Rafraîchir" onAction="#handleRafraichir"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
