<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns:fx="http://javafx.com/fxml" prefWidth="900" prefHeight="650"
            fx:controller="yoanemoudilou.cahiertexte.ui.dashboard.EnseignantDashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #123a63; -fx-padding: 15;">
            <Label fx:id="bienvenuLabel" text="Bienvenue" styleClass="header-label">
                <font><Font name="System Bold" size="18"/></font>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Nouvelle seance" onAction="#handleNouvelleSeance"
                    style="-fx-background-color: #f1c40f; -fx-text-fill: black;"/>
            <Button text="Deconnexion" onAction="#handleLogout"
                    style="-fx-background-color: #c0392b; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 20;">
            <TitledPane text="Mes statistiques" expanded="true">
                <GridPane hgap="40" vgap="10" style="-fx-padding: 15;">
                    <Label text="Mes cours:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="mesCoursCountLabel" text="0" style="-fx-font-weight: bold; -fx-font-size: 16;"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Mes seances:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <Label fx:id="mesSeancesCountLabel" text="0" style="-fx-font-weight: bold; -fx-font-size: 16;"
                           GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                    <Label text="En attente:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="seancesEnAttenteCountLabel" text="0"
                           style="-fx-font-weight: bold; -fx-text-fill: #e67e22;"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Validees:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                    <Label fx:id="seancesValideesCountLabel" text="0"
                           style="-fx-font-weight: bold; -fx-text-fill: #27ae60;"
                           GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                    <Label text="Rejetees:" GridPane.columnIndex="4" GridPane.rowIndex="1"/>
                    <Label fx:id="seancesRejeteesCountLabel" text="0"
                           style="-fx-font-weight: bold; -fx-text-fill: #c0392b;"
                           GridPane.columnIndex="5" GridPane.rowIndex="1"/>
                </GridPane>
            </TitledPane>

            <TitledPane text="Mes cours" expanded="true" VBox.vgrow="SOMETIMES">
                <TableView fx:id="mesCoursTable" prefHeight="150">
                    <columns>
                        <TableColumn fx:id="coursCodeColumn" text="Code" prefWidth="100"/>
                        <TableColumn fx:id="coursIntituleColumn" text="Intitule" prefWidth="250"/>
                        <TableColumn fx:id="coursClasseColumn" text="Classe" prefWidth="180"/>
                        <TableColumn fx:id="coursVolumeColumn" text="Volume (h)" prefWidth="100"/>
                    </columns>
                </TableView>
            </TitledPane>

            <TitledPane text="Mes dernieres seances" expanded="true" VBox.vgrow="ALWAYS">
                <TableView fx:id="dernieresSeancesTable" prefHeight="200">
                    <columns>
                        <TableColumn fx:id="seanceDateColumn" text="Date" prefWidth="100"/>
                        <TableColumn fx:id="seanceHeureColumn" text="Heure" prefWidth="80"/>
                        <TableColumn fx:id="seanceCoursColumn" text="Cours" prefWidth="150"/>
                        <TableColumn fx:id="seanceStatutColumn" text="Statut" prefWidth="100"/>
                        <TableColumn fx:id="seanceContenuColumn" text="Contenu" prefWidth="250"/>
                    </columns>
                </TableView>
            </TitledPane>

            <TitledPane text="Mes notifications" expanded="true" VBox.vgrow="SOMETIMES">
                <VBox spacing="10" style="-fx-padding: 12;">
                    <Label text="Notifications non lues:"/>
                    <Label fx:id="notificationsCountLabel" text="0" style="-fx-font-weight: bold; -fx-font-size: 16;"/>
                    <ListView fx:id="notificationsListView" prefHeight="120"/>
                </VBox>
            </TitledPane>

            <HBox spacing="15" alignment="CENTER">
                <Button text="Voir toutes mes seances" onAction="#handleVoirMesSeances"/>
                <Button text="Rafraichir" onAction="#handleRafraichir"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
