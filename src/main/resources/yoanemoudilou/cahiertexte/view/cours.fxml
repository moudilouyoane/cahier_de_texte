<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns:fx="http://javafx.com/fxml" prefWidth="900" prefHeight="600"
            fx:controller="yoanemoudilou.cahiertexte.ui.cours.CoursController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #2980b9; -fx-padding: 15;">
            <Label text="Gestion des cours" styleClass="header-label">
                <font>
                    <Font name="System Bold" size="18" />
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Retour au dashboard" onAction="#handleRetourDashboard" styleClass="button-accent" />
        </HBox>
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            <TableView fx:id="coursTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="50" />
                    <TableColumn fx:id="codeColumn" text="Code" prefWidth="100" />
                    <TableColumn fx:id="intituleColumn" text="Intitule" prefWidth="250" />
                    <TableColumn fx:id="volumeHoraireColumn" text="Volume (h)" prefWidth="110" />
                    <TableColumn fx:id="classeColumn" text="Classe / Filiere" prefWidth="280" />
                </columns>
            </TableView>

            <Separator />

            <GridPane hgap="15" vgap="10">
                <Label text="Code:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="codeField" prefWidth="150" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Intitule:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                <TextField fx:id="intituleField" prefWidth="250" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                <Label text="Volume horaire:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="volumeHoraireField" prefWidth="150" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Filiere:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <TextField fx:id="filiereField" prefWidth="250" editable="false" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                <Label text="Classe:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <ComboBox fx:id="classeComboBox" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Attribuer a:" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                <ComboBox fx:id="enseignantComboBox" prefWidth="250" GridPane.columnIndex="3" GridPane.rowIndex="2" />

                <Button text="Attribuer le cours" onAction="#handleAttribuerCours" prefWidth="160" GridPane.columnIndex="3" GridPane.rowIndex="3" />
            </GridPane>

            <HBox spacing="10" alignment="CENTER">
                <Button text="Nouveau" onAction="#handleNouveau" prefWidth="100" />
                <Button text="Enregistrer" onAction="#handleEnregistrer" prefWidth="100" style="-fx-background-color: #27ae60; -fx-text-fill: white;" />
                <Button text="Supprimer" onAction="#handleSupprimer" prefWidth="100" style="-fx-background-color: #c0392b; -fx-text-fill: white;" />
                <Button text="Rafraichir" onAction="#handleRafraichir" prefWidth="100" />
            </HBox>
        </VBox>
    </center>

</BorderPane>
