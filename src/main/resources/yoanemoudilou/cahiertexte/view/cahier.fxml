<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns:fx="http://javafx.com/fxml" prefWidth="1100" prefHeight="700"
            fx:controller="yoanemoudilou.cahiertexte.ui.cahier.CahierTexteController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label fx:id="titreLabel" text="Cahiers de texte" styleClass="header-label">
                <font><Font name="System Bold" size="18"/></font>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Classe :" styleClass="header-label-muted"/>
            <ComboBox fx:id="classeFilterComboBox" prefWidth="220" onAction="#handleFiltrer"/>
            <Button text="Rafraichir" onAction="#handleRafraichir"/>
            <Button text="Retour au dashboard" onAction="#handleRetourDashboard" styleClass="button-accent"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="12" style="-fx-padding: 20;">
            <Label fx:id="detailsLabel" text="Selectionne un cahier de texte."/>
            <Separator/>

            <SplitPane dividerPositions="0.36">
                <VBox spacing="10">
                    <Label text="Cahiers de texte">
                        <font><Font name="System Bold" size="14"/></font>
                    </Label>
                    <TableView fx:id="cahiersTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="cahierClasseColumn" text="Classe" prefWidth="170"/>
                            <TableColumn fx:id="cahierAnneeColumn" text="Annee" prefWidth="100"/>
                            <TableColumn fx:id="cahierSemestreColumn" text="Semestre" prefWidth="100"/>
                            <TableColumn fx:id="cahierDateCreationColumn" text="Creation" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox spacing="10">
                    <Label text="Contenu du cahier">
                        <font><Font name="System Bold" size="14"/></font>
                    </Label>
                    <TableView fx:id="seancesTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="seanceDateColumn" text="Date" prefWidth="90"/>
                            <TableColumn fx:id="seanceHeureColumn" text="Heure" prefWidth="80"/>
                            <TableColumn fx:id="seanceCoursColumn" text="Cours" prefWidth="230"/>
                            <TableColumn fx:id="seanceEnseignantColumn" text="Enseignant" prefWidth="170"/>
                            <TableColumn fx:id="seanceStatutColumn" text="Statut" prefWidth="100"/>
                            <TableColumn fx:id="seanceContenuColumn" text="Contenu" prefWidth="260"/>
                        </columns>
                    </TableView>
                </VBox>
            </SplitPane>
        </VBox>
    </center>

</BorderPane>
