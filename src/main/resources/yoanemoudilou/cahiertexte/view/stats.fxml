<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            prefWidth="1000" prefHeight="700"
            fx:controller="yoanemoudilou.cahiertexte.ui.stats.StatistiqueController">

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: linear-gradient(to right, #123a63, #2f6fad); -fx-padding: 15;">
            <Label text="📊 Statistiques" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="20"/>
                </font>
            </Label>
        </HBox>
    </top>

    <!-- Centre -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true">
            <VBox spacing="20" style="-fx-padding: 20;">

                <!-- ===== ZONE FILTRES ===== -->
                <TitledPane text="Filtres" expanded="true">
                    <VBox spacing="15" style="-fx-padding: 10;">
                        <HBox spacing="20" alignment="CENTER_LEFT">

                            <!-- Date début -->
                            <VBox spacing="5">
                                <Label text="Date début"/>
                                <DatePicker fx:id="dateDebutPicker" prefWidth="140"/>
                            </VBox>

                            <!-- Date fin -->
                            <VBox spacing="5">
                                <Label text="Date fin"/>
                                <DatePicker fx:id="dateFinPicker" prefWidth="140"/>
                            </VBox>

                            <!-- Classe -->
                            <VBox spacing="5">
                                <Label text="Classe"/>
                                <ComboBox fx:id="classeFilterComboBox" prefWidth="200" promptText="Toutes"/>
                            </VBox>

                            <!-- Enseignant -->
                            <VBox spacing="5">
                                <Label text="Enseignant"/>
                                <ComboBox fx:id="enseignantFilterComboBox" prefWidth="200" promptText="Tous"/>
                            </VBox>

                        </HBox>

                        <!-- Boutons de filtre -->
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <Button text="🔍 Filtrer" onAction="#handleFiltrer"
                                    style="-fx-background-color: #2f6fad; -fx-text-fill: white;"/>
                            <Button text="↩ Réinitialiser" onAction="#handleReinitialiserFiltres"
                                    style="-fx-background-color: #7f8c8d; -fx-text-fill: white;"/>
                            <Button text="🔄 Rafraîchir" onAction="#handleRafraichir"/>
                        </HBox>
                    </VBox>
                </TitledPane>

                <Separator/>

                <!-- ===== COMPTEURS GLOBAUX ===== -->
                <Label text="Vue d'ensemble">
                    <font>
                        <Font name="System Bold" size="16"/>
                    </font>
                </Label>

                <HBox spacing="20" alignment="CENTER">
                    <!-- Utilisateurs -->
                    <VBox alignment="CENTER" spacing="5"
                          style="-fx-background-color: #ecf0f1; -fx-padding: 20; -fx-background-radius: 8;">
                        <Label text="Utilisateurs" style="-fx-text-fill: #7f8c8d;"/>
                        <Label fx:id="totalUtilisateursLabel" text="0"
                               style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    </VBox>

                    <!-- Enseignants -->
                    <VBox alignment="CENTER" spacing="5"
                          style="-fx-background-color: #ecf0f1; -fx-padding: 20; -fx-background-radius: 8;">
                        <Label text="Enseignants" style="-fx-text-fill: #7f8c8d;"/>
                        <Label fx:id="totalEnseignantsLabel" text="0"
                               style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #16a085;"/>
                    </VBox>

                    <!-- Filières -->
                    <VBox alignment="CENTER" spacing="5"
                          style="-fx-background-color: #ecf0f1; -fx-padding: 20; -fx-background-radius: 8;">
                        <Label text="Filières" style="-fx-text-fill: #7f8c8d;"/>
                        <Label fx:id="totalFilieresLabel" text="0"
                               style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #8e44ad;"/>
                    </VBox>

                    <!-- Classes -->
                    <VBox alignment="CENTER" spacing="5"
                          style="-fx-background-color: #ecf0f1; -fx-padding: 20; -fx-background-radius: 8;">
                        <Label text="Classes" style="-fx-text-fill: #7f8c8d;"/>
                        <Label fx:id="totalClassesLabel" text="0"
                               style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2980b9;"/>
                    </VBox>

                    <!-- Cours -->
                    <VBox alignment="CENTER" spacing="5"
                          style="-fx-background-color: #ecf0f1; -fx-padding: 20; -fx-background-radius: 8;">
                        <Label text="Cours" style="-fx-text-fill: #7f8c8d;"/>
                        <Label fx:id="totalCoursLabel" text="0"
                               style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #e67e22;"/>
                    </VBox>

                    <!-- Séances -->
                    <VBox alignment="CENTER" spacing="5"
                          style="-fx-background-color: #d5f5e3; -fx-padding: 20; -fx-background-radius: 8;">
                        <Label text="Séances (filtrées)" style="-fx-text-fill: #7f8c8d;"/>
                        <Label fx:id="totalSeancesLabel" text="0"
                               style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                    </VBox>
                </HBox>

                <Separator/>

                <!-- ===== GRAPHIQUE + TABLEAU ===== -->
                <HBox spacing="25" VBox.vgrow="ALWAYS">

                    <!-- PieChart -->
                    <VBox alignment="CENTER" HBox.hgrow="SOMETIMES" minWidth="350">
                        <PieChart fx:id="statutPieChart"
                                  prefWidth="380" prefHeight="320"
                                  title="Répartition par statut"
                                  legendVisible="true"
                                  labelsVisible="true"/>
                    </VBox>

                    <!-- Tableau par enseignant -->
                    <VBox HBox.hgrow="ALWAYS" spacing="10">
                        <Label text="Détail par enseignant">
                            <font>
                                <Font name="System Bold" size="14"/>
                            </font>
                        </Label>

                        <TableView fx:id="statsEnseignantTable" VBox.vgrow="ALWAYS" minHeight="250">
                            <columns>
                                <TableColumn fx:id="enseignantNomColumn" text="Enseignant" prefWidth="200"/>
                                <TableColumn fx:id="enseignantTotalColumn" text="Total" prefWidth="80"/>
                                <TableColumn fx:id="enseignantValideesColumn" text="Validées" prefWidth="80"/>
                                <TableColumn fx:id="enseignantAttenteColumn" text="En attente" prefWidth="90"/>
                                <TableColumn fx:id="enseignantRejeteesColumn" text="Rejetées" prefWidth="80"/>
                            </columns>
                        </TableView>
                    </VBox>

                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>