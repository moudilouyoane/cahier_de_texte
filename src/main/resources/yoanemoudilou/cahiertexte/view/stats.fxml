<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            prefWidth="1000" prefHeight="700"
            fx:controller="yoanemoudilou.cahiertexte.ui.stats.StatistiqueController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: linear-gradient(to right, #123a63, #2f6fad); -fx-padding: 15;">
            <Label text="Statistiques" styleClass="header-label">
                <font>
                    <Font name="System Bold" size="20"/>
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Retour au dashboard" onAction="#handleRetourDashboard" styleClass="button-accent"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="18" style="-fx-padding: 20;">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <DatePicker fx:id="dateDebutPicker" promptText="Date début"/>
                <DatePicker fx:id="dateFinPicker" promptText="Date fin"/>
                <ComboBox fx:id="classeFilterComboBox" prefWidth="180" promptText="Classe"/>
                <ComboBox fx:id="enseignantFilterComboBox" prefWidth="220" promptText="Enseignant"/>
                <Button text="Filtrer" onAction="#handleFiltrer"/>
                <Button text="Réinitialiser" onAction="#handleReinitialiserFiltres" styleClass="button-accent"/>
                <Button text="Rafraîchir" onAction="#handleRafraichir"/>
            </HBox>

            <GridPane hgap="20" vgap="10">
                <Label text="Utilisateurs:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <Label fx:id="totalUtilisateursLabel" text="0" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <Label text="Enseignants:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <Label fx:id="totalEnseignantsLabel" text="0" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                <Label text="Cours:" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
                <Label fx:id="totalCoursLabel" text="0" GridPane.columnIndex="5" GridPane.rowIndex="0"/>
                <Label text="Séances:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <Label fx:id="totalSeancesLabel" text="0" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <Label text="Filières:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                <Label fx:id="totalFilieresLabel" text="0" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                <Label text="Classes:" GridPane.columnIndex="4" GridPane.rowIndex="1"/>
                <Label fx:id="totalClassesLabel" text="0" GridPane.columnIndex="5" GridPane.rowIndex="1"/>
            </GridPane>

            <PieChart fx:id="statutPieChart" prefHeight="260"/>

            <TableView fx:id="statsEnseignantTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="enseignantNomColumn" text="Enseignant" prefWidth="250"/>
                    <TableColumn fx:id="enseignantTotalColumn" text="Total" prefWidth="100"/>
                    <TableColumn fx:id="enseignantValideesColumn" text="Validées" prefWidth="100"/>
                    <TableColumn fx:id="enseignantAttenteColumn" text="En attente" prefWidth="100"/>
                    <TableColumn fx:id="enseignantRejeteesColumn" text="Rejetées" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </center>

</BorderPane>
