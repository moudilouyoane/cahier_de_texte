<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns:fx="http://javafx.com/fxml" prefWidth="700" prefHeight="500"
            fx:controller="yoanemoudilou.cahiertexte.ui.reports.ReportController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #d35400; -fx-padding: 15;">
            <Label text="Génération de rapports" styleClass="header-label">
                <font><Font name="System Bold" size="18"/></font>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Retour au dashboard" onAction="#handleRetourDashboard" styleClass="button-accent"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="25" alignment="CENTER" style="-fx-padding: 30;">
            <Label text="Sélectionne le type de rapport et les filtres">
                <font><Font size="14"/></font>
            </Label>

            <GridPane hgap="15" vgap="12" alignment="CENTER">
                <Label text="Date début:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <DatePicker fx:id="dateDebutPicker" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Date fin:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <DatePicker fx:id="dateFinPicker" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Statut:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <ComboBox fx:id="statutComboBox" prefWidth="180" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
            </GridPane>

            <HBox spacing="15" alignment="CENTER">
                <Button text="Filtrer" onAction="#handleFiltrer"/>
                <Button text="Réinitialiser" onAction="#handleResetFiltres" styleClass="button-accent"/>
            </HBox>

            <Label fx:id="totalLabel" text="Total : 0"/>

            <TableView fx:id="seancesTable" prefHeight="220" prefWidth="620">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="dateColumn" text="Date" prefWidth="90"/>
                    <TableColumn fx:id="heureColumn" text="Heure" prefWidth="80"/>
                    <TableColumn fx:id="coursColumn" text="Cours" prefWidth="150"/>
                    <TableColumn fx:id="enseignantColumn" text="Enseignant" prefWidth="140"/>
                    <TableColumn fx:id="statutColumn" text="Statut" prefWidth="100"/>
                    <TableColumn fx:id="dureeColumn" text="Durée" prefWidth="70"/>
                </columns>
            </TableView>

            <HBox spacing="15" alignment="CENTER">
                <Button text="Exporter PDF" onAction="#handleExporterPdf"/>
                <Button text="Exporter Excel" onAction="#handleExporterExcel" styleClass="button-accent"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
